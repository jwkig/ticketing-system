# Production environment.
# Copy to env/prod.env (git-ignored) and replace every CHANGE_ME value.
# Never commit the filled-in file.

# --- Postgres ---
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=ticketing

# --- Auth: generate a strong random key >= 32 bytes, e.g. `openssl rand -base64 48` ---
JWT_SECRET_KEY=CHANGE_ME_random_key_at_least_32_bytes_long
JWT_EXPIRATION_MINUTES=60

# --- URLs (public origin used in verification email links and CORS) ---
APP_BASE_URL=https://tickets.example.com
ANGULAR_ORIGIN=https://tickets.example.com

# --- Email ---
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=CHANGE_ME_smtp_password
