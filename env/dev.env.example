# Development environment.
# Copy to env/dev.env (git-ignored) and adjust if needed; defaults work out of the box.
# These vars are consumed for interpolation in the compose files (--env-file).

# --- Postgres (the API's connection string is assembled from these) ---
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=ticketing
POSTGRES_DB=ticketing

# --- Auth (dev-only key; never reuse for test/prod). Must be >= 32 bytes. ---
JWT_SECRET_KEY=dev-only-insecure-signing-key-change-me-at-least-32-bytes!!
JWT_EXPIRATION_MINUTES=60

# --- URLs (single nginx origin in the containerised dev stack) ---
APP_BASE_URL=http://localhost
ANGULAR_ORIGIN=http://localhost

# --- Email: captured by the MailDev container (UI at http://localhost:1080) ---
SMTP_HOST=maildev
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
