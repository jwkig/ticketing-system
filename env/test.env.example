# Test (staging-like) environment.
# Copy to env/test.env (git-ignored) and replace every CHANGE_ME value.

# --- Postgres ---
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=CHANGE_ME_test_db_password
POSTGRES_DB=ticketing

# --- Auth: generate a random key >= 32 bytes, e.g. `openssl rand -base64 48` ---
JWT_SECRET_KEY=CHANGE_ME_random_key_at_least_32_bytes_long
JWT_EXPIRATION_MINUTES=60

# --- URLs (web is published on :8081 for the test stack) ---
APP_BASE_URL=http://localhost:8081
ANGULAR_ORIGIN=http://localhost:8081

# --- Email (point at a real or sandbox SMTP relay) ---
SMTP_HOST=CHANGE_ME_smtp_host
SMTP_PORT=587
SMTP_USER=CHANGE_ME_smtp_user
SMTP_PASSWORD=CHANGE_ME_smtp_password
